---
const links = [
  { href: '/about',     label: 'About'     },
  { href: '/events',    label: 'Events'    },
  { href: '/gallery',   label: 'Gallery'   },
  { href: '/resources', label: 'Resources' },
  { href: '/contact',   label: 'Team'      },
];
const current = Astro.url.pathname;
---
<nav class="sticky top-0 z-50 bg-[#0B0F14]/80 backdrop-blur border-b border-white/10">
  <div class="container mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="text-[#00FF9F] font-bold text-lg tracking-wide hover:opacity-80 transition">
      FSU Cyber Club
    </a>
    <div class="flex items-center gap-6 text-sm">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class={`transition hover:text-[#00FF9F] ${current === href ? 'text-[#00FF9F] font-semibold' : 'text-[#E5E7EB]'}`}
        >
          {label}
        </a>
      ))}
      <a
        href="/join"
        class="ml-2 px-4 py-1.5 rounded bg-[#00FF9F] text-[#0B0F14] font-semibold hover:opacity-90 transition"
      >
        Join Us
      </a>
    </div>
  </div>
</nav>
