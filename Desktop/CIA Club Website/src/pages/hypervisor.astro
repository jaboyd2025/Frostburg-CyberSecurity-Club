---
import Layout from '../components/Layout.astro';
---

<Layout title="What is a Hypervisor? — Frostburg Cybersecurity Club">

  <!-- Back link -->
  <div class="max-w-3xl mx-auto px-4 pt-10">
    <a href="/resources" class="text-[#E5E7EB]/70 hover:text-[#00FF9F] text-base font-semibold transition">
      ← Back to Resources
    </a>
  </div>

  <!-- Header -->
  <section class="max-w-3xl mx-auto px-4 pt-8 pb-12">
    <span class="text-[#3B82F6] text-sm font-mono tracking-widest uppercase">Virtualization</span>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold text-[#E5E7EB]">
      What is a <span class="text-[#00FF9F]">Hypervisor?</span>
    </h1>
    <div class="h-0.5 rounded-full mt-6 mb-8" style="background: linear-gradient(to right, #00FF9F, transparent);"></div>
    <p class="text-[#E5E7EB]/80 text-lg leading-relaxed">
      A <span class="text-[#00FF9F] font-semibold">hypervisor</span> (also called a Virtual Machine Monitor, or VMM) is software that creates and manages virtual machines (VMs). It sits between the hardware and the operating system, allowing multiple operating systems to run simultaneously on a single physical machine — each in its own isolated environment.
    </p>
  </section>

  <!-- Why it matters -->
  <section class="max-w-3xl mx-auto px-4 pb-14">
    <h2 class="text-2xl font-bold text-[#E5E7EB] mb-5">Why Does This Matter in Cybersecurity?</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {[
        { icon: '🧪', title: 'Safe Lab Environments', desc: 'Run intentionally vulnerable machines (like those from VulnHub) without risking your real system.' },
        { icon: '🐉', title: 'Kali Linux on Any Machine', desc: 'Install Kali Linux as a VM on Windows or macOS and have a full pentesting OS ready to go.' },
        { icon: '🔒', title: 'Malware Analysis', desc: 'Analyze malware inside an isolated VM — if it wrecks the VM, your real files are untouched.' },
        { icon: '🔁', title: 'Snapshots & Rollbacks', desc: 'Take a snapshot before testing anything risky, then roll back instantly if something breaks.' },
      ].map(({ icon, title, desc }) => (
        <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:border-[#00FF9F]/30 transition">
          <div class="text-2xl mb-3">{icon}</div>
          <h3 class="text-[#E5E7EB] font-semibold mb-1">{title}</h3>
          <p class="text-[#E5E7EB]/55 text-sm leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Type 1 vs Type 2 -->
  <section class="max-w-3xl mx-auto px-4 pb-14">
    <h2 class="text-2xl font-bold text-[#E5E7EB] mb-6">Type 1 vs Type 2 Hypervisors</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Type 1 -->
      <div class="bg-white/5 border border-[#3B82F6]/30 rounded-xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-[#3B82F6]/20 border border-[#3B82F6]/40 flex items-center justify-center text-lg">1</div>
          <div>
            <h3 class="text-[#E5E7EB] font-bold">Type 1 — Bare Metal</h3>
            <p class="text-[#3B82F6] text-xs font-mono">Runs directly on hardware</p>
          </div>
        </div>
        <p class="text-[#E5E7EB]/60 text-sm leading-relaxed mb-4">
          Installed directly on the physical hardware with no underlying OS. Maximum performance and used in enterprise data centers.
        </p>
        <div class="space-y-1">
          {['VMware ESXi', 'Microsoft Hyper-V', 'Citrix XenServer'].map((name) => (
            <p class="text-xs font-mono text-[#E5E7EB]/50 flex items-center gap-2">
              <span class="text-[#3B82F6]">▸</span>{name}
            </p>
          ))}
        </div>
      </div>

      <!-- Type 2 -->
      <div class="bg-white/5 border border-[#00FF9F]/30 rounded-xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-[#00FF9F]/10 border border-[#00FF9F]/30 flex items-center justify-center text-lg">2</div>
          <div>
            <h3 class="text-[#E5E7EB] font-bold">Type 2 — Hosted</h3>
            <p class="text-[#00FF9F] text-xs font-mono">Runs on top of a host OS</p>
          </div>
        </div>
        <p class="text-[#E5E7EB]/60 text-sm leading-relaxed mb-4">
          Runs as an application on top of an existing OS like Windows or macOS. Easier to set up — perfect for students and home labs.
        </p>
        <div class="space-y-1">
          {['VirtualBox (free)', 'VMware Workstation', 'Parallels Desktop'].map((name) => (
            <p class="text-xs font-mono text-[#E5E7EB]/50 flex items-center gap-2">
              <span class="text-[#00FF9F]">▸</span>{name}
            </p>
          ))}
        </div>
      </div>

    </div>

    <!-- Diagram -->
    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6 font-mono text-xs text-center text-[#E5E7EB]/60 leading-loose">
      <p class="text-[#00FF9F] font-bold text-sm mb-4">How a Type 2 Hypervisor Works</p>
      <div class="space-y-1">
        <div class="bg-[#3B82F6]/10 border border-[#3B82F6]/30 rounded px-4 py-2 text-[#3B82F6]">Guest OS (e.g. Kali Linux)</div>
        <div class="text-[#E5E7EB]/30">↕ virtual hardware</div>
        <div class="bg-[#00FF9F]/10 border border-[#00FF9F]/30 rounded px-4 py-2 text-[#00FF9F]">Hypervisor (VirtualBox / VMware)</div>
        <div class="text-[#E5E7EB]/30">↕ runs on top of</div>
        <div class="bg-white/5 border border-white/20 rounded px-4 py-2">Host OS (Windows / macOS / Linux)</div>
        <div class="text-[#E5E7EB]/30">↕</div>
        <div class="bg-white/5 border border-white/20 rounded px-4 py-2">Physical Hardware</div>
      </div>
    </div>
  </section>

  <!-- Download CTA -->
  <section class="max-w-3xl mx-auto px-4 pb-20 border-t border-white/10 pt-12">
    <h2 class="text-xl font-bold text-[#E5E7EB] mb-2">Ready to Set Up Your Lab?</h2>
    <p class="text-[#E5E7EB]/60 text-sm mb-6">Download one of the tools below and start running virtual machines on your own machine.</p>
    <div class="flex flex-wrap gap-4">
      <a
        href="https://www.virtualbox.org/wiki/Downloads"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-6 py-3 rounded bg-[#1565c0] text-white font-bold hover:opacity-90 transition"
      >
        📦 Download VirtualBox ↗
      </a>
      <a
        href="https://www.vmware.com/products/desktop-hypervisor/workstation-and-fusion"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-6 py-3 rounded bg-[#607d8b] text-white font-bold hover:opacity-90 transition"
      >
        🖥️ Download VMware Workstation ↗
      </a>
    </div>
  </section>

</Layout>
