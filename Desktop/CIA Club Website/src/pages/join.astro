---
import Layout from '../components/Layout.astro';
---
<Layout title="Join the Club — FSU Cybersecurity Club">

  <section class="min-h-[80vh] flex flex-col items-center justify-center text-center px-4 py-24 gap-8">

    <!-- Icon -->
    <div class="text-6xl">🛡️</div>

    <!-- Heading -->
    <div class="flex flex-col gap-3 max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-extrabold text-[#E5E7EB]">
        Become a <span class="text-[#00FF9F]">Member</span>
      </h1>
      <p class="text-lg md:text-xl text-[#E5E7EB]/70 leading-relaxed">
        Our Discord is the heartbeat of the club. It's where meetings are announced,
        events are coordinated, resources are shared, and members connect. Whether you're
        a seasoned hacker or just getting started, joining the server is your first step
        into the community.
      </p>
    </div>

    <!-- What you'll get -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 w-full max-w-3xl mt-2">
      <div class="bg-white/5 border border-white/10 rounded-xl p-5 text-left hover:border-[#00FF9F]/40 transition">
        <div class="text-2xl mb-3">📅</div>
        <h3 class="font-semibold text-[#E5E7EB] mb-1">Meeting Updates</h3>
        <p class="text-sm text-[#E5E7EB]/60">Get notified the moment a new meeting is scheduled so you never miss out.</p>
      </div>
      <div class="bg-white/5 border border-white/10 rounded-xl p-5 text-left hover:border-[#00FF9F]/40 transition">
        <div class="text-2xl mb-3">🎯</div>
        <h3 class="font-semibold text-[#E5E7EB] mb-1">Events & CTFs</h3>
        <p class="text-sm text-[#E5E7EB]/60">Be the first to know about competitions, workshops, and club events.</p>
      </div>
      <div class="bg-white/5 border border-white/10 rounded-xl p-5 text-left hover:border-[#00FF9F]/40 transition">
        <div class="text-2xl mb-3">🤝</div>
        <h3 class="font-semibold text-[#E5E7EB] mb-1">Member Network</h3>
        <p class="text-sm text-[#E5E7EB]/60">Connect with fellow members, share resources, and collaborate on projects.</p>
      </div>
    </div>

    <!-- Discord CTA -->
    <a
      href="https://discord.gg/EeMWeAjW"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-4 inline-flex items-center gap-3 px-8 py-4 rounded-lg bg-[#5865F2] text-white font-bold text-lg hover:opacity-90 transition shadow-lg shadow-[#5865F2]/30"
    >
      <!-- Discord logo SVG -->
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 127.14 96.36" fill="currentColor">
        <path d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"/>
      </svg>
      Join Our Discord
    </a>

    <p class="text-[#E5E7EB]/40 text-sm">Free to join. Open to all FSU students.</p>

  </section>

</Layout>
