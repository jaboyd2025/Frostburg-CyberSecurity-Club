---
import Layout from '../components/Layout.astro';
---

<Layout title="Team — Frostburg Cybersecurity Club">

  <!-- Page Header -->
  <section class="pt-16 pb-12 text-center px-4">
    <span class="text-[#00FF9F] text-sm font-mono tracking-widest uppercase">Meet the Team</span>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold text-[#E5E7EB]">
      Our <span class="text-[#00FF9F]">Team</span>
    </h1>
    <p class="mt-4 text-[#E5E7EB]/60 max-w-xl mx-auto">
      Reach out to our faculty lead or club officers through the channels below.
    </p>
  </section>

  <!-- Faculty Lead -->
  <section class="max-w-3xl mx-auto px-4 pb-20">
    <div class="text-center mb-10">
      <span class="text-[#3B82F6] text-sm font-mono tracking-widest uppercase">Faculty</span>
      <h2 class="mt-3 text-2xl font-bold text-[#E5E7EB]">Faculty <span class="text-[#3B82F6]">Lead</span></h2>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-xl p-8 hover:border-[#3B82F6]/40 transition">
      <h3 class="text-xl font-semibold text-[#E5E7EB] mb-1">Dr. Zhijang Chen</h3>
      <p class="text-[#00FF9F] text-sm font-mono mb-6">Faculty Lead</p>

      <div class="flex flex-col sm:flex-row gap-4">
        <!-- Email -->
        <a
          href="mailto:zchen@frostburg.edu"
          class="flex items-center gap-3 px-5 py-3 rounded-lg bg-white/5 border border-white/10 hover:border-[#00FF9F]/40 transition group flex-1"
        >
          <svg class="w-5 h-5 text-[#00FF9F] shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <div>
            <p class="text-xs text-[#E5E7EB]/40 font-mono uppercase tracking-wide">Email</p>
            <p class="text-[#E5E7EB] text-sm group-hover:text-[#00FF9F] transition">zchen@frostburg.edu</p>
          </div>
        </a>

        <!-- Microsoft Teams -->
        <a
          href="https://teams.microsoft.com/l/chat/0/0?users=zchen@frostburg.edu"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 px-5 py-3 rounded-lg bg-white/5 border border-white/10 hover:border-[#3B82F6]/40 transition group flex-1"
        >
          <svg class="w-5 h-5 text-[#3B82F6] shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.625 7.5h-3.375V6a3 3 0 00-3-3h-1.5a3 3 0 00-3 3v1.5H6.375A1.875 1.875 0 004.5 9.375v9.75A1.875 1.875 0 006.375 21h14.25A1.875 1.875 0 0022.5 19.125v-9.75A1.875 1.875 0 0020.625 7.5zM12 9a2.25 2.25 0 110 4.5A2.25 2.25 0 0112 9zm3.75 9H8.25v-.375a3.75 3.75 0 017.5 0V18z"/>
          </svg>
          <div>
            <p class="text-xs text-[#E5E7EB]/40 font-mono uppercase tracking-wide">Microsoft Teams</p>
            <p class="text-[#E5E7EB] text-sm group-hover:text-[#3B82F6] transition">zchen@frostburg.edu</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Club Officers -->
  <section class="max-w-3xl mx-auto px-4 pb-20">
    <div class="text-center mb-10">
      <span class="text-[#00FF9F] text-sm font-mono tracking-widest uppercase">Leadership</span>
      <h2 class="mt-3 text-2xl font-bold text-[#E5E7EB]">Club <span class="text-[#00FF9F]">Officers</span></h2>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-xl p-8 hover:border-[#00FF9F]/40 transition">
      <h3 class="text-xl font-semibold text-[#E5E7EB] mb-1">Armenta Farmer</h3>
      <p class="text-[#00FF9F] text-sm font-mono mb-6">President</p>

      <div class="flex flex-col sm:flex-row gap-4">
        <!-- Email -->
        <a
          href="mailto:ajfarmer0@frostburg.edu"
          class="flex items-center gap-3 px-5 py-3 rounded-lg bg-white/5 border border-white/10 hover:border-[#00FF9F]/40 transition group flex-1"
        >
          <svg class="w-5 h-5 text-[#00FF9F] shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <div>
            <p class="text-xs text-[#E5E7EB]/40 font-mono uppercase tracking-wide">Email</p>
            <p class="text-[#E5E7EB] text-sm group-hover:text-[#00FF9F] transition">ajfarmer0@frostburg.edu</p>
          </div>
        </a>

        <!-- Microsoft Teams -->
        <a
          href="https://teams.microsoft.com/l/chat/0/0?users=ajfarmer0@frostburg.edu"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 px-5 py-3 rounded-lg bg-white/5 border border-white/10 hover:border-[#3B82F6]/40 transition group flex-1"
        >
          <svg class="w-5 h-5 text-[#3B82F6] shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.625 7.5h-3.375V6a3 3 0 00-3-3h-1.5a3 3 0 00-3 3v1.5H6.375A1.875 1.875 0 004.5 9.375v9.75A1.875 1.875 0 006.375 21h14.25A1.875 1.875 0 0022.5 19.125v-9.75A1.875 1.875 0 0020.625 7.5zM12 9a2.25 2.25 0 110 4.5A2.25 2.25 0 0112 9zm3.75 9H8.25v-.375a3.75 3.75 0 017.5 0V18z"/>
          </svg>
          <div>
            <p class="text-xs text-[#E5E7EB]/40 font-mono uppercase tracking-wide">Microsoft Teams</p>
            <p class="text-[#E5E7EB] text-sm group-hover:text-[#3B82F6] transition">ajfarmer0@frostburg.edu</p>
          </div>
        </a>
      </div>
    </div>
  </section>

</Layout>
