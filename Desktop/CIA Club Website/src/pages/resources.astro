---
import Layout from '../components/Layout.astro';
import { tools } from '../data/tools.js';

const labs = [
  {
    name: 'TryHackMe',
    difficulty: 'Beginner → Intermediate',
    description:
      'A browser-based cybersecurity training platform with guided, gamified learning paths. No setup required — just spin up a virtual machine and start hacking.',
    teaches: ['Linux fundamentals', 'Web exploitation', 'Network security', 'CTF skills'],
    url: 'https://tryhackme.com',
    color: '#ef4444',
  },
  {
    name: 'Hack The Box',
    difficulty: 'Intermediate → Advanced',
    description:
      'An elite hacking training platform with real-world machines, challenges, and competitive rankings. Sharpens offensive and defensive skills through hands-on practice.',
    teaches: ['Privilege escalation', 'Active Directory attacks', 'Reverse engineering', 'Binary exploitation'],
    url: 'https://www.hackthebox.com',
    color: '#00FF9F',
  },
  {
    name: 'PicoCTF',
    difficulty: 'Beginner → Intermediate',
    description:
      'A free computer security education program with a CTF competition designed for middle and high school students, but great for any beginner. Created by Carnegie Mellon University.',
    teaches: ['Cryptography', 'Forensics', 'Reverse engineering', 'Web exploitation'],
    url: 'https://picoctf.org',
    color: '#3b82f6',
  },
  {
    name: 'OverTheWire',
    difficulty: 'Beginner → Advanced',
    description:
      'A series of wargames that teach Linux command-line skills, networking, and security concepts through progressively difficult challenges. Bandit is the perfect starting point.',
    teaches: ['Linux command line', 'Bash scripting', 'Cryptography', 'Networking basics'],
    url: 'https://overthewire.org/wargames/',
    color: '#f59e0b',
  },
  {
    name: 'OWASP WebGoat',
    difficulty: 'Beginner → Intermediate',
    description:
      'A deliberately insecure web application maintained by OWASP that allows developers and security professionals to test vulnerabilities in a safe, legal environment.',
    teaches: ['SQL injection', 'XSS attacks', 'Authentication flaws', 'OWASP Top 10'],
    url: 'https://owasp.org/www-project-webgoat/',
    color: '#7c3aed',
  },
  {
    name: 'VulnHub',
    difficulty: 'Intermediate → Advanced',
    description:
      'Provides downloadable virtual machines that are intentionally vulnerable for hands-on security practice. Great for building a home lab and practicing full penetration testing methodology.',
    teaches: ['Full pentest workflow', 'Vulnerability exploitation', 'Post-exploitation', 'Report writing'],
    url: 'https://www.vulnhub.com',
    color: '#ec4899',
  },
];
---

<Layout title="Resources — Frostburg Cybersecurity Club">

  <!-- Page Header -->
  <section class="pt-16 pb-12 text-center px-4">
    <span class="text-[#00FF9F] text-sm font-mono tracking-widest uppercase">Learn & Practice</span>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold text-[#E5E7EB]">
      Club <span class="text-[#00FF9F]">Resources</span>
    </h1>
    <p class="mt-4 text-[#E5E7EB]/60 max-w-xl mx-auto">
      Tools used by the pros and labs to sharpen your skills — all in one place.
    </p>
  </section>

  <!-- ── TOOLS ── -->
  <section class="py-16 border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4">

      <div class="text-center mb-12">
        <span class="text-[#3B82F6] text-sm font-mono tracking-widest uppercase">Software</span>
        <h2 class="mt-2 text-3xl font-bold text-[#E5E7EB]">Security <span class="text-[#00FF9F]">Tools</span></h2>
        <p class="mt-3 text-[#E5E7EB]/60 max-w-xl mx-auto">
          Click any tool to learn what it does and where to get it.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
        {tools.map((tool) => (
          <a
            href={`/tools/${tool.slug}`}
            class="group flex flex-col items-center gap-3 p-6 rounded-xl border border-white/10 bg-white/5 hover:border-[#00FF9F]/40 hover:bg-white/10 transition text-center"
          >
            <!-- Icon circle -->
            <div
              class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl shadow-lg group-hover:scale-110 transition duration-200"
              style={`background: ${tool.color}22; border: 1px solid ${tool.color}55;`}
            >
              {tool.icon}
            </div>
            <div>
              <p class="text-[#E5E7EB] font-semibold text-sm">{tool.name}</p>
              <p class="text-[#E5E7EB]/50 text-xs mt-0.5">{tool.tagline}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ── VIRTUALIZATION ── -->
  <section class="py-16 border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4">

      <div class="text-center mb-12">
        <span class="text-[#3B82F6] text-sm font-mono tracking-widest uppercase">Lab Setup</span>
        <h2 class="mt-2 text-3xl font-bold text-[#E5E7EB]">Virtualization <span class="text-[#00FF9F]">Tools</span></h2>
        <p class="mt-3 text-[#E5E7EB]/60 max-w-xl mx-auto">
          Run isolated virtual machines on your own computer — essential for any cybersecurity lab.
          <a href="/hypervisor" class="text-[#3B82F6] hover:underline ml-1">What is a hypervisor? →</a>
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- VirtualBox -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-8 hover:border-[#1565c0]/60 transition flex flex-col gap-6">
          <div class="flex items-center gap-5">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl shadow-lg flex-shrink-0" style="background: #1565c022; border: 1px solid #1565c055;">
              📦
            </div>
            <div>
              <h3 class="text-xl font-bold text-[#E5E7EB]">VirtualBox</h3>
              <p class="text-[#E5E7EB]/50 text-sm">Free & open-source · Oracle</p>
              <span class="text-xs font-mono text-[#1565c0]">Windows · macOS · Linux</span>
            </div>
          </div>
          <p class="text-[#E5E7EB]/60 text-sm leading-relaxed">
            The go-to free hypervisor for students. Run Kali Linux, vulnerable VMs, and isolated lab environments safely without touching your main OS.
          </p>
          <div class="flex flex-wrap gap-3 mt-auto">
            <a
              href="https://www.virtualbox.org/wiki/Downloads"
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-2.5 rounded bg-[#1565c0] text-white font-bold hover:opacity-90 transition text-sm"
            >
              Download VirtualBox ↗
            </a>
          </div>
        </div>

        <!-- VMware Workstation -->
        <div class="bg-white/5 border border-white/10 rounded-xl p-8 hover:border-[#607d8b]/60 transition flex flex-col gap-6">
          <div class="flex items-center gap-5">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-3xl shadow-lg flex-shrink-0" style="background: #607d8b22; border: 1px solid #607d8b55;">
              🖥️
            </div>
            <div>
              <h3 class="text-xl font-bold text-[#E5E7EB]">VMware Workstation</h3>
              <p class="text-[#E5E7EB]/50 text-sm">Professional-grade · Broadcom</p>
              <span class="text-xs font-mono text-[#90a4ae]">Windows · Linux</span>
            </div>
          </div>
          <p class="text-[#E5E7EB]/60 text-sm leading-relaxed">
            Industry-standard virtualization used by security engineers worldwide. Offers advanced networking, VM encryption, and high-performance guest OS support.
          </p>
          <div class="flex flex-wrap gap-3 mt-auto">
            <a
              href="https://www.vmware.com/products/desktop-hypervisor/workstation-and-fusion"
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-2.5 rounded bg-[#607d8b] text-white font-bold hover:opacity-90 transition text-sm"
            >
              Download VMware ↗
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── LABS ── -->
  <section class="py-16 border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4">

      <div class="text-center mb-12">
        <span class="text-[#3B82F6] text-sm font-mono tracking-widest uppercase">Hands-On Practice</span>
        <h2 class="mt-2 text-3xl font-bold text-[#E5E7EB]">Training <span class="text-[#00FF9F]">Labs</span></h2>
        <p class="mt-3 text-[#E5E7EB]/60 max-w-xl mx-auto">
          Real environments to practice real skills. Click any lab to go to the platform.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {labs.map((lab) => (
          <a
            href={lab.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block rounded-xl border border-white/10 bg-white/5 hover:border-[#00FF9F]/40 hover:bg-white/10 transition overflow-hidden"
          >
            <!-- Colored top bar -->
            <div class="h-1.5" style={`background: ${lab.color};`} />

            <div class="p-6">
              <div class="flex items-start justify-between gap-4 mb-3">
                <div>
                  <h3 class="text-lg font-bold text-[#E5E7EB] group-hover:text-[#00FF9F] transition">{lab.name}</h3>
                  <span class="text-xs font-mono" style={`color: ${lab.color};`}>{lab.difficulty}</span>
                </div>
                <!-- External link arrow -->
                <span class="text-[#E5E7EB]/30 group-hover:text-[#00FF9F] transition text-lg mt-0.5">↗</span>
              </div>

              <p class="text-[#E5E7EB]/60 text-sm leading-relaxed mb-4">{lab.description}</p>

              <!-- Skills tags -->
              <div class="flex flex-wrap gap-2">
                {lab.teaches.map((skill) => (
                  <span class="text-xs px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[#E5E7EB]/60">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>
