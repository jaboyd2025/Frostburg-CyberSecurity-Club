---
import Layout from '../components/Layout.astro';
---
<Layout title="Frostburg Cybersecurity Club">

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex flex-col items-center justify-center text-center px-4 py-24 gap-6 overflow-hidden">
    <img
      src="/87f3f1425b217691da645e97dbb50d55.gif"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover opacity-20 pointer-events-none"
    />
    <span class="text-[#00FF9F] text-sm font-mono tracking-widest uppercase">
      Frostburg State University
    </span>
    <h1 class="text-5xl md:text-6xl font-extrabold leading-tight text-[#E5E7EB]">
      Frostburg<br />
      <span class="text-[#00FF9F]">Cybersecurity</span> Club
    </h1>
    <p class="text-xl md:text-2xl text-[#E5E7EB]/70 max-w-2xl">
      Building the Next Generation of Cyber Defenders
    </p>
    <div class="flex flex-wrap gap-4 justify-center mt-4">
      <a
        href="/join"
        class="px-6 py-3 rounded bg-[#00FF9F] text-[#0B0F14] font-bold text-base hover:opacity-90 transition"
      >
        Join the Club
      </a>
      <a
        href="/about"
        class="px-6 py-3 rounded border border-[#3B82F6] text-[#3B82F6] font-semibold text-base hover:bg-[#3B82F6]/10 transition"
      >
        Learn More
      </a>
    </div>
  </section>

  <!-- What We Do -->
  <section class="py-20 border-t border-white/10">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12 text-[#E5E7EB]">
        What We <span class="text-[#00FF9F]">Do</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <div class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-[#00FF9F]/40 transition">
          <div class="text-3xl mb-4">🛡️</div>
          <h3 class="text-lg font-semibold text-[#E5E7EB] mb-2">Hands-On Training</h3>
          <p class="text-[#E5E7EB]/60 text-sm leading-relaxed">
            Practice real-world skills through CTF competitions, labs, and guided workshops on topics like network security, cryptography, and web exploitation.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-[#00FF9F]/40 transition">
          <div class="text-3xl mb-4">🤝</div>
          <h3 class="text-lg font-semibold text-[#E5E7EB] mb-2">Community & Networking</h3>
          <p class="text-[#E5E7EB]/60 text-sm leading-relaxed">
            Connect with fellow students, faculty, and industry professionals who share a passion for cybersecurity and information assurance.
          </p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-xl p-6 hover:border-[#00FF9F]/40 transition">
          <div class="text-3xl mb-4">🚀</div>
          <h3 class="text-lg font-semibold text-[#E5E7EB] mb-2">Career Development</h3>
          <p class="text-[#E5E7EB]/60 text-sm leading-relaxed">
            Explore certifications, internships, and career paths in cybersecurity. Build a portfolio that stands out to employers.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-20 border-t border-white/10">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-[#E5E7EB] mb-4">
        Ready to defend the digital frontier?
      </h2>
      <p class="text-[#E5E7EB]/60 mb-8">
        No experience required — just curiosity and a willingness to learn. All Frostburg State University students are welcome.
      </p>
      <a
        href="/join"
        class="inline-block px-8 py-3 rounded bg-[#00FF9F] text-[#0B0F14] font-bold text-base hover:opacity-90 transition"
      >
        Join Us Today
      </a>
    </div>
  </section>

</Layout>
